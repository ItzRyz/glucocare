{
  "experimentalServices": {
    "frontend": {
      "entrypoint": ".",
      "framework": "nextjs",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "py_service/index.py",
      "routePrefix": "/api/flask",
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/flask/(.*)",
      "dest": "/api/flask/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}